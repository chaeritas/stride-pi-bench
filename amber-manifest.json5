{
  manifest_version: "0.1.0",

  config_schema: {
    type: "object",
    properties: {
      OPENAI_API_KEY: { type: "string", secret: true },
    },
    required: ["OPENAI_API_KEY"],
    additionalProperties: false,
  },

  slots: {
    proxy: { kind: "a2a", optional: true },
  },

  program: {
    image: "ghcr.io/chaeritas/stride-pi-bench:latest",
    entrypoint: "python src/server.py --host 0.0.0.0 --port 9009",

    env: {
      OPENAI_API_KEY: "${config.OPENAI_API_KEY}",
    },

    network: {
      endpoints: [
        { name: "a2a_endpoint", port: 9009 },
      ],
    },
  },

  provides: {
    a2a: { kind: "a2a", endpoint: "a2a_endpoint" },
  },

  exports: { a2a: "a2a" },
}
